# eGain Visitor InSite — environment configuration
# Optional: copy to .env when you want to override defaults or add provider keys.

# OpenAI API key — OPTIONAL.
# Without a key, the app serves pre-seeded AI content baked into the Docker
# image at build time. Set this to enable live AI generation and regeneration.
OPENAI_API_KEY=

OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_RETRIES=6
OPENAI_MAX_INPUT_TOKENS=3000

# Express server port. Docker exposes 3082; leave this at 3082 unless you
# change the docker-compose ports mapping too.
PORT=3082

# Path to a specific log run directory.
# Leave blank to auto-discover the latest run under src/log-generator/logs/.
# LOG_DIR=

# IP enrichment provider used by parse.js.
# mock        = deterministic synthetic IP -> company/firmographic data.
# kickfire    = KickFire B2B IP lookup for real IP experiments.
ENRICHMENT_PROVIDER=mock

# KickFire B2B company enrichment used by parse.js when ENRICHMENT_PROVIDER=kickfire
# and by /api/enrichment/resolve-company.
# Add the real key only to your local .env, never to this template.
KICKFIRE_API_KEY=
KICKFIRE_API_BASE_URL=https://api.kickfire.com/v3

# Set to false to bypass the 1-hour AI regeneration cooldown during development.
REGEN_RATE_LIMIT_ENABLED=true
